#!/bin/bash

src_dir="."
out_dir="../docs"

mkdir -p "$out_dir"
cp style.css "$out_dir/style.css"

find "$src_dir" -type f -name "*.md" | while read -r md; do
  rel="${md#./}"
  html="${rel%.md}.html"
  out="${out_dir}/${html}"

  mkdir -p "$(dirname "$out")"

  # rel のディレクトリ部分
  dir="$(dirname "$rel")"

  # CSS への相対パスを決める
  if [ "$dir" = "." ]; then
    css_path="style.css"
  else
    depth=$(echo "$dir" | awk -F/ '{print NF}')
    css_path=""
    for i in $(seq 1 "$depth"); do
      css_path="../$css_path"
    done
    css_path="${css_path}style.css"
  fi

  pandoc "$md" -s -c "$css_path" -o "$out"
done
